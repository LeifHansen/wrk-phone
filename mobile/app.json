{
  "expo": {
    "name": "WrkPhn",
    "slug": "wrk-phone",
    "scheme": "wrkphn",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF8EC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wrkphn.app",
      "buildNumber": "1",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "WrkPhn uses the microphone so you can make and receive voice calls on your work line.",
        "NSContactsUsageDescription": "WrkPhn syncs your contacts so caller names show in your inbox and AI agents can recognize known senders. Sync is optional and only runs when you tap Sync.",
        "NSUserTrackingUsageDescription": "WrkPhn does not track you across other companies' apps or websites.",
        "UIBackgroundModes": ["voip", "audio", "remote-notification"],
        "LSApplicationQueriesSchemes": ["tel", "sms", "mailto"],
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDevelopmentRegion": "en",
        "CFBundleLocalizations": ["en"]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.wrkphn.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF8EC"
      },
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "POST_NOTIFICATIONS",
        "READ_CONTACTS",
        "VIBRATE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_PHONE_CALL",
        "USE_FULL_SCREEN_INTENT",
        "BLUETOOTH_CONNECT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-contacts",
        { "contactsPermission": "Allow WrkPhn to sync your contacts so names show on calls and texts." }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://wrkphn.com"
    }
  }
}
