{
  "expo": {
    "name": "WrkPhn",
    "slug": "wrk-phone",
    "scheme": "wrkphn",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourco.wrkphn",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "WrkPhn needs the mic for calls.",
        "NSContactsUsageDescription": "WrkPhn syncs your contacts so names show on calls and texts, and your agents can recognize known people.",
        "UIBackgroundModes": ["voip", "audio", "remote-notification"]
      }
    },
    "android": {
      "package": "com.yourco.wrkphn",
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "POST_NOTIFICATIONS",
        "READ_CONTACTS"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-contacts",
        { "contactsPermission": "Allow WrkPhn to sync your contacts so names show on calls and texts." }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://wrk-phone-8ebcfd.fly.dev"
    }
  }
}
