{
  "expo": {
    "name": "WrkPhn",
    "slug": "wrk-phone",
    "scheme": "wrkphn",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF8EC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wrkphn.app",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "WrkPhn needs the mic for calls.",
        "NSContactsUsageDescription": "WrkPhn syncs your contacts so names show on calls and texts, and your agents can recognize known people.",
        "UIBackgroundModes": ["voip", "audio", "remote-notification"]
      }
    },
    "android": {
      "package": "com.wrkphn.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF8EC"
      },
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "POST_NOTIFICATIONS",
        "READ_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-contacts",
        { "contactsPermission": "Allow WrkPhn to sync your contacts so names show on calls and texts." }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://wrkphn.com"
    }
  }
}
