# Copy this file to server/.env and fill in REAL values there.
# server/.env is gitignored. NEVER put real credentials in this .env.example file —
# it is committed to git.

# --- Server ---
PORT=4000
# Public https URL Twilio reaches for inbound calls/SMS (ngrok / cloudflared / deployed).
PUBLIC_BASE_URL=https://your-tunnel.ngrok.app

# --- Cloudflare (optional: stable named tunnel instead of the ephemeral quick URL) ---
CLOUDFLARE_API_TOKEN=cfut_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PUSH_CREDENTIAL_SID_IOS=CRxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PUSH_CREDENTIAL_SID_ANDROID=CRxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_DEFAULT_FROM_NUMBER=+15555550123

# --- OpenAI ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# --- Stripe (credit purchases) ---
# Without these, paid packages credit instantly without charging (dev fallback).
# Real values go in server/.env (gitignored) + Fly secrets — NEVER here.
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Auth (single-user demo) ---
DEMO_USER_ID=demo
